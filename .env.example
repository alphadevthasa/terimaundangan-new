# Session signing (JWT auth via jose — lib/session.ts)
# Generate with: openssl rand -base64 48   (min 32 chars)
SESSION_SECRET="generate_with_openssl_rand_base64_48"

# Database
DATABASE_URL="postgresql://user:password@host:5432/db"

# Cloudflare (domain + Pages)
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token"
CLOUDFLARE_ACCOUNT_ID="your_account_id"
CLOUDFLARE_PAGES_API_TOKEN="your_pages_api_token"

# NextAuth
NEXTAUTH_SECRET="your_nextauth_secret"
NEXTAUTH_URL="https://your-domain.com"

# Xendit
XENDIT_API_KEY="xnd_development_your_key"
XENDIT_WEBHOOK_VERIFICATION_TOKEN="your_webhook_token"

# SendGrid (transactional email)
SENDGRID_API_KEY="your_sendgrid_key"
SENDGRID_FROM_EMAIL="noreply@your-domain.com"
SENDGRID_FROM_NAME="Your Name"

# Loops (marketing email)
LOOPS_API_KEY="your_loops_key"

# GitHub (template repo cloning)
GITHUB_TOKEN="your_github_token"

# Render (self URL for webhook callbacks)
RENDER_URL="https://your-app.onrender.com"

# Public app URL
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# App Mode
NODE_ENV=development
NEXT_PUBLIC_SHOW_SIMULATE=true

# Name.com
NAMECOM_API_BASE=https://api.name.com
NAME_USERNAME=your_username
NAME_API_TOKEN=your_api_token
ADMIN_LINK_GENERATOR=true

# R2 Cloudflare Dev Env:
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=webforge-assets
R2_PUBLIC_URL=https://pub-your-id.r2.dev

# Google Cloud
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# TOTP Encryption Key
TOTP_ENCRYPTION_KEY=your_64_hex_encryption_key

# DEWABIZ
DEWABIZ_RESELLER_ID=your_reseller_id
DEWABIZ_API_KEY=your_api_key
DEWABIZ_TLDS=id,co.id,my.id,web.id,biz.id
DEWABIZ_DEFAULT_NS1=ns1.deployan.com
DEWABIZ_DEFAULT_NS2=ns2.deployan.com
DEWABIZ_MOCK_ALL=true

DOMAIN_PURCHASE_DRY_RUN=true

UNSPLASH_ACCESS_KEY=your_unsplash_key
